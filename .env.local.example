# ──────────────────────────────────────────────────────────────────
# Calendario 5°F — Variables de entorno Firebase
# ──────────────────────────────────────────────────────────────────
# 1. Copia este archivo como .env.local
# 2. Rellena los valores con las credenciales de tu proyecto Firebase
#    (Firebase Console → Configuración del proyecto → Tus apps → SDK)
# 3. NUNCA subas .env.local a Git
# ──────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
